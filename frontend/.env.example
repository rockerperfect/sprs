# Frontend Environment Variables
# Copy this file to .env.local for local development

# The full URL of your deployed backend API including /api/v1
# Example (Railway):  VITE_API_URL=https://sprs-backend.up.railway.app/api/v1
# Example (Render):   VITE_API_URL=https://sprs-backend.onrender.com/api/v1
# Leave empty for local dev (falls back to http://localhost:5000/api/v1)
VITE_API_URL=
